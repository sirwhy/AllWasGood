# =============================================================================
# Pippit Clone — Environment Variables
# Copy to .env and fill in. NEVER commit .env to git.
# =============================================================================

# --- Core ---
# Public URL where the app is served (used for OAuth, callbacks, share links).
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_NAME="Pippit Clone"

# --- Auth (NextAuth/Auth.js v5) ---
# Generate with: openssl rand -base64 32
AUTH_SECRET=changeme-generate-with-openssl-rand-base64-32
AUTH_TRUST_HOST=true

# Optional OAuth providers (leave blank to disable)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# --- Database (Postgres) ---
# Railway provides this automatically when you add a Postgres plugin.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pippit?schema=public

# --- Redis (for BullMQ job queue) ---
# Railway provides this automatically when you add a Redis plugin.
REDIS_URL=redis://localhost:6379

# --- Object Storage (S3-compatible: AWS S3, Cloudflare R2, Backblaze, MinIO) ---
# Used to store generated images/videos and uploaded assets.
STORAGE_PROVIDER=local           # local | s3
S3_ENDPOINT=                     # e.g. https://<account>.r2.cloudflarestorage.com
S3_REGION=auto
S3_BUCKET=pippit-assets
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_URL=                   # public CDN URL prefix, e.g. https://cdn.example.com

# --- Encryption (for user-supplied API keys stored in DB) ---
# 32-byte key, base64 encoded. Generate with: openssl rand -base64 32
CREDENTIAL_ENCRYPTION_KEY=changeme-generate-with-openssl-rand-base64-32

# --- Default / fallback provider keys (OPTIONAL) ---
# Users can override these per-account in the Settings page. These act as
# fallbacks if a user has not configured their own keys.
OPENAI_API_KEY=
OPENAI_BASE_URL=                 # for OpenAI-compatible endpoints (Groq, Together, Ollama, vLLM, LM Studio)
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=
REPLICATE_API_TOKEN=
FAL_API_KEY=
STABILITY_API_KEY=
ELEVENLABS_API_KEY=
HEYGEN_API_KEY=
DID_API_KEY=
DEEPGRAM_API_KEY=

# --- Social media auto-posting (optional) ---
# Twitter / X — https://developer.x.com/
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
# LinkedIn — https://www.linkedin.com/developers/apps
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
# YouTube (Google Cloud OAuth) — https://console.cloud.google.com/apis/credentials
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
# TikTok — https://developers.tiktok.com/
TIKTOK_CLIENT_ID=
TIKTOK_CLIENT_SECRET=
# Meta family (Instagram / Facebook / Threads) — https://developers.facebook.com/
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
THREADS_CLIENT_ID=
THREADS_CLIENT_SECRET=

# --- Worker ---
WORKER_CONCURRENCY=4
NODE_ENV=development
